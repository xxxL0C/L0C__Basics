{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../",
          "files": ["XXXL0C.ExBasics.csproj"]
        }
      ],
      "output": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["../_site/**"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "../_site/ja",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "L0C__ExBasics",
      "_appTitle": "L0C__ExBasics",
      "_enableSearch": true,
      "pdf": true
    }
  }
}
